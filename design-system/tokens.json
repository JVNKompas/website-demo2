{
  "$schema": "https://design-tokens.org/format/",
  "$description": "JVN Kompas — Design tokens (W3C-style). Dark is de standaardmodus; light is de equivalent.",
  "color": {
    "$type": "color",
    "brand": {
      "copper": {
        "300": { "$value": "#F4A24C", "$description": "ember / hover-highlight" },
        "400": { "$value": "#EE8F35" },
        "500": { "$value": "#E8802A", "$description": "primair accent (base)" },
        "600": { "$value": "#CC6A1C" },
        "700": { "$value": "#A5530F", "$description": "copper-tekst op licht (AA)" }
      },
      "steel": {
        "300": { "$value": "#8FB3C2" },
        "500": { "$value": "#4A6B7A", "$description": "secundair / structureel, gedempt" },
        "700": { "$value": "#2E4753" }
      }
    },
    "neutral": {
      "onyx": {
        "950": { "$value": "#0C0D10", "$description": "paginabasis (dark)" },
        "900": { "$value": "#111318" },
        "850": { "$value": "#16181D", "$description": "surface / kaart" },
        "800": { "$value": "#1D2026", "$description": "verhoogde surface" },
        "700": { "$value": "#2A2E36", "$description": "border / divider" },
        "600": { "$value": "#3A3F49" },
        "500": { "$value": "#565C68" }
      },
      "slate": {
        "400": { "$value": "#9A9DA6", "$description": "secundaire tekst (dark)" },
        "300": { "$value": "#C4C7CE" }
      },
      "bone": {
        "100": { "$value": "#EDEAE3", "$description": "primaire tekst (dark)" },
        "50": { "$value": "#F7F5F0", "$description": "paginabasis (light)" }
      }
    },
    "semantic": {
      "success": { "$value": "#3F9D6B" },
      "success-fg": { "$value": "#7FD9A6" },
      "warning": { "$value": "#E5B84B" },
      "warning-fg": { "$value": "#F2CF77" },
      "danger": { "$value": "#D4453B" },
      "danger-fg": { "$value": "#F0847C" },
      "info": { "$value": "#4A87A8" },
      "info-fg": { "$value": "#8FB9CF" }
    }
  },
  "theme": {
    "dark": {
      "bg": { "$value": "{color.neutral.onyx.950}" },
      "surface": { "$value": "{color.neutral.onyx.850}" },
      "surface-raised": { "$value": "{color.neutral.onyx.800}" },
      "border": { "$value": "{color.neutral.onyx.700}" },
      "text": { "$value": "{color.neutral.bone.100}" },
      "text-muted": { "$value": "{color.neutral.slate.400}" },
      "accent": { "$value": "{color.brand.copper.500}" },
      "accent-hover": { "$value": "{color.brand.copper.300}" },
      "on-accent": { "$value": "{color.neutral.onyx.950}" }
    },
    "light": {
      "bg": { "$value": "{color.neutral.bone.50}" },
      "surface": { "$value": "#FFFFFF" },
      "surface-raised": { "$value": "#FFFFFF" },
      "border": { "$value": "#E2DED4" },
      "text": { "$value": "{color.neutral.onyx.900}" },
      "text-muted": { "$value": "#5B606B" },
      "accent": { "$value": "{color.brand.copper.700}" },
      "accent-hover": { "$value": "{color.brand.copper.600}" },
      "on-accent": { "$value": "{color.neutral.bone.50}" }
    }
  },
  "typography": {
    "family": {
      "display": { "$value": "'Space Grotesk', system-ui, sans-serif" },
      "body": { "$value": "'IBM Plex Sans', system-ui, sans-serif" },
      "mono": { "$value": "'IBM Plex Mono', ui-monospace, monospace" }
    },
    "size": {
      "$type": "dimension",
      "xs": { "$value": "0.75rem" },
      "sm": { "$value": "0.875rem" },
      "base": { "$value": "1rem" },
      "md": { "$value": "1.25rem" },
      "lg": { "$value": "1.5625rem" },
      "xl": { "$value": "1.953rem" },
      "2xl": { "$value": "2.441rem" },
      "3xl": { "$value": "3.052rem" },
      "4xl": { "$value": "3.815rem" }
    },
    "weight": {
      "regular": { "$value": "400" },
      "medium": { "$value": "500" },
      "semibold": { "$value": "600" },
      "bold": { "$value": "700" }
    },
    "leading": {
      "tight": { "$value": "1.1" },
      "snug": { "$value": "1.3" },
      "normal": { "$value": "1.6" }
    },
    "tracking": {
      "tight": { "$value": "-0.02em" },
      "normal": { "$value": "0em" },
      "wide": { "$value": "0.08em" }
    }
  },
  "space": {
    "$type": "dimension",
    "0": { "$value": "0" },
    "0.5": { "$value": "4px" },
    "1": { "$value": "8px" },
    "2": { "$value": "16px" },
    "3": { "$value": "24px" },
    "4": { "$value": "32px" },
    "5": { "$value": "48px" },
    "6": { "$value": "64px" },
    "7": { "$value": "96px" },
    "8": { "$value": "128px" }
  },
  "radius": {
    "$type": "dimension",
    "none": { "$value": "0" },
    "sm": { "$value": "4px" },
    "md": { "$value": "8px" },
    "lg": { "$value": "14px" },
    "pill": { "$value": "999px" }
  },
  "border": {
    "$type": "dimension",
    "hairline": { "$value": "1px" },
    "thick": { "$value": "2px" }
  },
  "elevation": {
    "0": { "$value": "none" },
    "1": { "$value": "0 1px 2px rgba(0,0,0,0.4)" },
    "2": { "$value": "0 8px 24px rgba(0,0,0,0.45)" },
    "accent": { "$value": "0 6px 24px rgba(232,128,42,0.28)" }
  },
  "breakpoint": {
    "$type": "dimension",
    "sm": { "$value": "375px" },
    "md": { "$value": "768px" },
    "lg": { "$value": "1024px" },
    "xl": { "$value": "1440px" }
  },
  "motion": {
    "duration": {
      "instant": { "$value": "120ms" },
      "fast": { "$value": "180ms" },
      "base": { "$value": "240ms" },
      "slow": { "$value": "320ms" },
      "entrance": { "$value": "480ms" }
    },
    "easing": {
      "standard": { "$value": "cubic-bezier(0.2, 0, 0, 1)" },
      "decelerate": { "$value": "cubic-bezier(0, 0, 0, 1)" },
      "accelerate": { "$value": "cubic-bezier(0.3, 0, 1, 1)" },
      "emphasized": { "$value": "cubic-bezier(0.2, 0, 0, 1.1)" }
    }
  }
}
