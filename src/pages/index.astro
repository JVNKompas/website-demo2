---
import Base from '../layouts/Base.astro';
import ServiceCard from '../components/ServiceCard.astro';
import WorkCard from '../components/WorkCard.astro';
import Testimonials from '../components/Testimonials.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { diensten, cases } from '../data/site.js';
const featured = cases.slice(0, 3);
const stappen = [
  { t: 'Kennismaking', d: 'We bespreken vrijblijvend je idee, doel en budget.' },
  { t: 'Ontwerp', d: 'Ik vertaal het naar een concreet, helder voorstel.' },
  { t: 'Uitwerking', d: 'Alles wordt vakkundig gebouwd en tot in de puntjes afgewerkt.' },
  { t: 'Oplevering', d: 'Je krijgt het resultaat klaar voor gebruik, met uitleg.' },
];
---
<Base title="JVN Kompas — jouw persoonlijk kompas in een complexe digitale wereld">
  <!-- HERO -->
  <section class="hero">
    <div class="hero-media" aria-hidden="true">
      <img class="hero-img" src="/img/hero-img.jpg" alt="" />
      <span class="hero-overlay"></span>
    </div>
    <div class="wrap hero-inner">
      <div class="hero-text">
        <span class="eyebrow slogan">Digitaal op koers</span>
        <h1 class="hero-title">Jouw persoonlijk kompas in een complexe digitale wereld</h1>
        <p class="lead hero-sub">Van website en branding tot 3D-print en IT-ondersteuning. Lokaal, persoonlijk en resultaatgericht.</p>
        <div class="hero-actions">
          <a href="/offerte" class="btn btn--primary">Vraag een offerte aan</a>
          <a href="/werk" class="btn btn--ghost">Bekijk projecten</a>
        </div>
        <p class="hero-meta mono">Voor lokale zelfstandigen, KMO’s, verenigingen &amp; particulieren</p>
      </div>
    </div>
  </section>

  <!-- DIENSTEN -->
  <section class="section">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="eyebrow"><span class="idx">01</span> / Diensten</span>
        <h2>Vier disciplines, één aanspreekpunt</h2>
      </div>
      <div class="grid grid-4 svc-grid">
        {diensten.map((d) => <ServiceCard d={d} />)}
      </div>
    </div>
  </section>

  <div class="wrap"><hr class="koers" /></div>

  <!-- PROJECTEN -->
  <section class="section">
    <div class="wrap">
      <div class="sec-head sec-head--row reveal">
        <div>
          <span class="eyebrow"><span class="idx">02</span> / Projecten</span>
          <h2>Recente projecten</h2>
        </div>
        <a href="/werk" class="link-arrow">Alle projecten <span class="a">→</span></a>
      </div>
      <div class="grid grid-3">
        {featured.map((c) => <WorkCard c={c} />)}
      </div>
    </div>
  </section>

  <!-- AANPAK -->
  <section class="section proces-sec">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="eyebrow">Aanpak / Zo werken we</span>
        <h2>Van eerste gesprek tot resultaat</h2>
      </div>
      <div class="proces">
        {stappen.map((s, i) => (
          <div class="proces-step reveal" style={`transition-delay:${i * 180}ms`}>
            <span class="mono proces-num">{String(i + 1).padStart(2, '0')}</span>
            <span class="proces-label">{s.t}</span>
            <span class="proces-desc muted">{s.d}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Testimonials />

  <CtaBanner />
</Base>

<style>
  /* Full-bleed hero: donkerder beeld vult de hele sectie, tekst eroverheen */
  .hero{position:relative;display:flex;align-items:center;
    min-height:clamp(540px,84vh,780px);overflow:hidden}
  .hero-media{position:absolute;inset:0;z-index:0}
  .hero-img{width:100%;height:100%;object-fit:cover;object-position:62% center;filter:brightness(.5)}
  .hero-overlay{position:absolute;inset:0;
    background:
      linear-gradient(90deg,rgba(26,26,26,.97) 0%,rgba(26,26,26,.9) 34%,rgba(26,26,26,.62) 66%,rgba(26,26,26,.5) 100%),
      linear-gradient(0deg,rgba(26,26,26,.8) 0%,transparent 46%)}
  .hero-inner{position:relative;z-index:1;width:100%;padding-block:clamp(48px,8vw,96px)}
  .hero-text{max-width:min(94vw,900px)}
  .slogan{color:var(--accent);letter-spacing:.16em}
  .hero-title{font-size:clamp(1.9rem,3.4vw,2.6rem);margin-top:1rem;line-height:1.12;text-wrap:balance;max-width:24ch}
  .hero-sub{margin-top:1.4rem;color:var(--bone-100);max-width:60ch;text-shadow:0 1px 12px rgba(0,0,0,.4)}
  .hero-actions{display:flex;gap:.8rem;margin-top:2rem;flex-wrap:wrap}
  .hero-meta{margin-top:1.6rem;font-size:.78rem;color:var(--slate-300);letter-spacing:.04em}
  /* Titel op één lijn op ruime schermen */
  @media (min-width:1200px){
    .hero-title{white-space:nowrap;max-width:none}
  }

  .sec-head{margin-bottom:var(--space-4)}
  .sec-head h2{font-size:var(--fs-2xl);margin-top:.5rem;max-width:18ch}
  .sec-head--row{display:flex;justify-content:space-between;align-items:flex-end;gap:1rem}

  .proces{display:grid;grid-template-columns:repeat(4,1fr);gap:var(--space-4);
    border-top:1px solid var(--border);padding-top:var(--space-4)}
  .proces-step{display:flex;flex-direction:column;gap:.5rem;position:relative;padding-left:1rem}
  .proces-step::before{content:"";position:absolute;left:0;top:.15rem;width:2px;height:2.4rem;background:var(--accent);opacity:.5}
  .proces-num{color:var(--accent);font-size:.85rem}
  .proces-label{font-family:var(--font-display);font-weight:600;font-size:1.2rem}
  .proces-desc{font-size:.92rem;line-height:1.5}

  @media (max-width:900px){
    .hero{min-height:auto;padding-block:0}
    .hero-img{object-position:65% center}
    .hero-overlay{background:
      linear-gradient(90deg,rgba(26,26,26,.95) 0%,rgba(26,26,26,.84) 55%,rgba(26,26,26,.66) 100%),
      linear-gradient(0deg,rgba(26,26,26,.88) 0%,transparent 55%)}
    .proces{grid-template-columns:repeat(2,1fr);gap:var(--space-3)}
    .sec-head h2{font-size:var(--fs-xl)}
  }
  @media (max-width:520px){
    .proces{grid-template-columns:1fr}
  }
</style>
