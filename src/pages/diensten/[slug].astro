---
import Base from '../../layouts/Base.astro';
import WorkCard from '../../components/WorkCard.astro';
import Faq from '../../components/Faq.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import { diensten, cases } from '../../data/site.js';

export function getStaticPaths() {
  return diensten.map((d) => ({ params: { slug: d.slug }, props: { d } }));
}
const { d } = Astro.props;
const related = cases.filter((c) => c.disc === d.disc).slice(0, 3);
const jsonld = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: d.titel,
  description: d.subline,
  areaServed: 'Vlaanderen',
  provider: { '@type': 'ProfessionalService', name: 'JVN Kompas' },
};
---
<Base title={`${d.titel} — JVN Kompas`} description={d.subline} jsonld={jsonld}>
  <!-- HERO -->
  <section class="section svc-hero">
    <div class="wrap">
      <nav class="crumbs mono" aria-label="Kruimelpad">
        <a href="/diensten">Diensten</a> <span aria-hidden="true">/</span> <span>{d.titel}</span>
      </nav>
      <span class="badge">{d.disc}</span>
      <h1>{d.heroTitel}</h1>
      <p class="lead">{d.subline}</p>
      <a href={`/offerte?dienst=${d.slug}`} class="btn btn--primary hero-cta">{d.cta}</a>
    </div>
  </section>

  <!-- BENEFITS -->
  <section class="section--tight">
    <div class="wrap">
      <div class="benefits">
        {d.benefits.map((b, i) => (
          <div class="benefit reveal">
            <span class="mono benefit-num">{String(i + 1).padStart(2, '0')}</span>
            <h3>{b.t}</h3>
            <p class="muted">{b.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DELIVERABLES + PROCES -->
  <section class="section">
    <div class="wrap two-col">
      <div class="reveal">
        <span class="eyebrow"><span class="idx">Wat</span> / Je krijgt</span>
        <h2>Wat er in zit</h2>
        <ul class="deliver">
          {d.deliverables.map((x) => <li><span class="check" aria-hidden="true">✓</span>{x}</li>)}
        </ul>
      </div>
      <div class="reveal">
        <span class="eyebrow"><span class="idx">Hoe</span> / De aanpak</span>
        <h2>Zo werk ik</h2>
        <ol class="steps">
          {d.proces.map((p, i) => (
            <li><span class="mono steps-num">{String(i + 1).padStart(2, '0')}</span><span>{p}</span></li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  {related.length > 0 && (
    <section class="section--tight">
      <div class="wrap">
        <div class="sec-head--row">
          <h2 class="rel-h">Werk in {d.titel.toLowerCase()}</h2>
          <a href={`/werk?disc=${d.disc}`} class="link-arrow">Meer {d.disc} <span class="a">→</span></a>
        </div>
        <div class="grid grid-3">{related.map((c) => <WorkCard c={c} />)}</div>
      </div>
    </section>
  )}

  <Faq items={d.faqs} title={`Vragen over ${d.titel.toLowerCase()}`} />

  <CtaBanner
    title="Klaar voor je project?"
    primary={{ label: d.cta, href: `/offerte?dienst=${d.slug}` }}
    secondary={{ label: 'Plan een gesprek', href: '/contact' }}
  />
</Base>

<style>
  .svc-hero .badge{margin-bottom:1rem;display:inline-block}
  .crumbs{font-size:.78rem;color:var(--text-muted);margin-bottom:1.4rem}
  .crumbs a:hover{color:var(--accent)}
  .svc-hero h1{font-size:var(--fs-3xl);max-width:16ch}
  .svc-hero .lead{margin-top:1.2rem}
  .hero-cta{margin-top:2rem}
  .benefits{display:grid;grid-template-columns:repeat(3,1fr);gap:var(--space-3)}
  .benefit{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:var(--space-4)}
  .benefit-num{color:var(--accent);font-size:.85rem}
  .benefit h3{font-size:1.2rem;margin:.6rem 0 .6rem}
  .two-col{display:grid;grid-template-columns:1fr 1fr;gap:var(--space-5)}
  .two-col h2{font-size:var(--fs-xl);margin:.6rem 0 1.2rem}
  .deliver{list-style:none;display:flex;flex-direction:column;gap:.8rem}
  .deliver li{display:flex;gap:.7rem;align-items:center;padding-bottom:.8rem;border-bottom:1px solid var(--border)}
  .check{color:var(--accent);font-weight:700}
  .steps{list-style:none;counter-reset:s;display:flex;flex-direction:column;gap:.8rem}
  .steps li{display:flex;gap:1rem;align-items:center;padding-bottom:.8rem;border-bottom:1px solid var(--border);font-family:var(--font-display);font-weight:600}
  .steps-num{color:var(--accent);font-size:.85rem;font-family:var(--font-mono);font-weight:400}
  .rel-h{font-size:var(--fs-xl)}
  @media (max-width:900px){
    .benefits{grid-template-columns:1fr}
    .two-col{grid-template-columns:1fr;gap:var(--space-4)}
    .svc-hero h1{font-size:var(--fs-2xl)}
  }
</style>
