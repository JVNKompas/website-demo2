---
import Base from '../layouts/Base.astro';
import { site } from '../data/site.js';
---
<Base title="Contact — JVN Kompas" description="Zet je project in gang. Binnen twee werkdagen een eerlijk antwoord.">
  <section class="section page-head">
    <div class="wrap">
      <span class="eyebrow"><span class="idx">Contact</span> / Zet het in gang</span>
      <h1>Zet je project in gang</h1>
      <p class="lead">Vertel kort wat je nodig hebt. Je krijgt binnen twee werkdagen een eerlijk antwoord — of het nu een website, logo of print is.</p>
    </div>
  </section>

  <section class="section--tight">
    <div class="wrap contact-grid">
      <form class="contact-form card" id="contactForm" novalidate>
        <div class="field">
          <label for="naam">Naam</label>
          <input id="naam" name="naam" required autocomplete="name" />
          <span class="err" data-err></span>
        </div>
        <div class="field">
          <label for="email">E-mail</label>
          <input id="email" name="email" type="email" required autocomplete="email" />
          <span class="err" data-err></span>
        </div>
        <div class="field">
          <label for="tel">Telefoon <span class="opt">(optioneel)</span></label>
          <input id="tel" name="tel" type="tel" autocomplete="tel" />
        </div>
        <div class="field">
          <label for="onderwerp">Waarover gaat het?</label>
          <select id="onderwerp" name="onderwerp" required>
            <option value="">Kies een discipline…</option>
            <option>Webdesign</option>
            <option>Logo &amp; branding</option>
            <option>3D-printen</option>
            <option>IT-support</option>
            <option>Iets anders</option>
          </select>
          <span class="err" data-err></span>
        </div>
        <div class="field">
          <label for="bericht">Je bericht</label>
          <textarea id="bericht" name="bericht" rows="5" required></textarea>
          <span class="err" data-err></span>
        </div>
        <label class="consent">
          <input type="checkbox" id="consent" name="consent" required />
          <span>Ik ga akkoord met het <a href="/privacybeleid">privacybeleid</a>.</span>
        </label>
        <button class="btn btn--primary" type="submit" id="submitBtn">Verstuur bericht</button>
        <p class="form-status" id="formStatus" role="status"></p>
      </form>

      <aside class="contact-aside">
        <div class="card">
          <h2>Liever meteen bellen?</h2>
          <p class="muted">Plan zelf een gratis kennismaking van 20 minuten, of neem rechtstreeks contact op.</p>
          <div class="contact-details">
            <a href={`mailto:${site.email}`} class="detail"><span class="mono">E-mail</span>{site.email}</a>
            <a href={`tel:${site.telefoonHref}`} class="detail"><span class="mono">Telefoon</span>{site.telefoon}</a>
            <span class="detail"><span class="mono">Regio</span>{site.regio} &amp; omstreken</span>
          </div>
          <a href="#" class="btn btn--ghost booking">Plan een kennismaking</a>
        </div>
        <div class="card map" role="img" aria-label="Kaart van de regio">
          <span class="mono map-label">Regio {site.regio}</span>
        </div>
      </aside>
    </div>
  </section>
</Base>

<style>
  .page-head{padding-bottom:0}
  .page-head h1{font-size:var(--fs-3xl);margin-top:1rem}
  .page-head .lead{margin-top:1.2rem}
  .contact-grid{display:grid;grid-template-columns:1.3fr 1fr;gap:var(--space-4);align-items:start}
  .contact-form{display:flex;flex-direction:column;gap:1.1rem}
  .field{display:flex;flex-direction:column;gap:.4rem}
  .field label{font-size:.9rem;font-weight:500}
  .opt{color:var(--text-muted);font-weight:400}
  .field input,.field select,.field textarea{
    min-height:48px;padding:.7rem .9rem;background:var(--onyx-900);border:1px solid var(--border);
    border-radius:var(--radius-md);color:var(--text);font-family:var(--font-body);font-size:1rem}
  .field textarea{min-height:auto;resize:vertical}
  .field input:focus-visible,.field select:focus-visible,.field textarea:focus-visible{border-color:var(--accent)}
  .field.invalid input,.field.invalid select,.field.invalid textarea{border-color:var(--danger)}
  .err{color:var(--danger);font-size:.8rem;min-height:1em}
  .consent{display:flex;gap:.6rem;align-items:flex-start;font-size:.9rem;color:var(--slate-300)}
  .consent input{width:20px;height:20px;margin-top:2px;accent-color:var(--accent);flex:none}
  .consent a{color:var(--accent);text-decoration:underline}
  .form-status{min-height:1.4em;font-size:.9rem}
  .form-status.ok{color:var(--success)}
  .form-status.err{color:var(--danger)}
  .contact-aside{display:flex;flex-direction:column;gap:var(--space-3)}
  .contact-aside h2{font-size:var(--fs-lg);margin-bottom:.6rem}
  .contact-details{display:flex;flex-direction:column;gap:.8rem;margin:1.2rem 0}
  .detail{display:flex;flex-direction:column;gap:.15rem;padding-bottom:.8rem;border-bottom:1px solid var(--border)}
  .detail .mono{font-size:.72rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.1em}
  .detail:hover{color:var(--accent)}
  .booking{width:100%}
  .map{aspect-ratio:16/10;background:
    linear-gradient(150deg,#241a17,var(--onyx-900));position:relative;
    background-image:repeating-linear-gradient(0deg,transparent,transparent 22px,rgba(232,93,58,.06) 23px),
      repeating-linear-gradient(90deg,transparent,transparent 22px,rgba(232,93,58,.06) 23px)}
  .map-label{position:absolute;left:16px;bottom:14px;font-size:.72rem;color:var(--copper-300)}
  @media (max-width:900px){
    .contact-grid{grid-template-columns:1fr}
    .page-head h1{font-size:var(--fs-2xl)}
  }
</style>

<script define:vars={{ inbox: site.aanvraagEmail }}>
  const form = document.getElementById('contactForm');
  const status = document.getElementById('formStatus');
  const btn = document.getElementById('submitBtn');
  const emailRe = /^[^@\s]+@[^@\s]+\.[^@\s]+$/;

  const setErr = (field, msg) => {
    const wrap = field.closest('.field');
    if (wrap) { wrap.classList.toggle('invalid', !!msg); const e = wrap.querySelector('[data-err]'); if (e) e.textContent = msg; }
  };
  const validate = () => {
    let ok = true;
    const checks = [
      ['naam', form.naam.value.trim() ? '' : 'Vul je naam in.'],
      ['email', emailRe.test(form.email.value.trim()) ? '' : 'Vul een geldig e-mailadres in.'],
      ['onderwerp', form.onderwerp.value ? '' : 'Kies een discipline.'],
      ['bericht', form.bericht.value.trim().length >= 10 ? '' : 'Vertel iets meer (min. 10 tekens).'],
    ];
    checks.forEach(([name, msg]) => { setErr(form[name], msg); if (msg) ok = false; });
    return ok;
  };
  form.addEventListener('input', (e) => { if (e.target.closest('.field.invalid')) validate(); });
  form.addEventListener('submit', (e) => {
    e.preventDefault();
    status.className = 'form-status';
    if (!validate()) { status.className = 'form-status err'; status.textContent = 'Controleer de gemarkeerde velden.'; return; }
    if (!form.consent.checked) { status.className = 'form-status err'; status.textContent = 'Bevestig het privacybeleid om te versturen.'; return; }
    // Voorlopig: aanvraag via e-mail (mailto) naar de studio-inbox.
    const subject = `Nieuwe aanvraag via website — ${form.onderwerp.value}`;
    const body =
      `Naam: ${form.naam.value}\n` +
      `E-mail: ${form.email.value}\n` +
      `Telefoon: ${form.tel.value || '-'}\n` +
      `Onderwerp: ${form.onderwerp.value}\n\n` +
      `Bericht:\n${form.bericht.value}\n`;
    window.location.href = `mailto:${inbox}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    status.className = 'form-status ok';
    status.textContent = 'Je e-mailprogramma opent met je aanvraag — verstuur de mail om het af te ronden. Lukt dat niet? Mail rechtstreeks naar info@jvnkompas.be.';
  });
</script>
