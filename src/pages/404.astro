---
import Base from '../layouts/Base.astro';
---
<Base title="Pagina niet gevonden — JVN Kompas" description="Deze pagina bestaat niet (meer).">
  <section class="section notfound">
    <div class="wrap">
      <span class="compass404" aria-hidden="true"></span>
      <span class="eyebrow"><span class="idx">404</span> / Uit koers</span>
      <h1>Deze pagina staat niet op de kaart</h1>
      <p class="lead">De link klopt niet meer of de pagina is verplaatst. Laten we je terug op koers zetten.</p>
      <div class="nf-actions">
        <a href="/" class="btn btn--primary">Naar de homepagina</a>
        <a href="/werk" class="btn btn--ghost">Bekijk het werk</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .notfound{min-height:60vh;display:flex;align-items:center}
  .notfound h1{font-size:var(--fs-2xl);margin:1rem 0 1.2rem;max-width:16ch}
  .compass404{display:block;width:72px;height:72px;border-radius:50%;border:2px solid var(--copper-600);
    position:relative;margin-bottom:2rem;animation:spin 8s linear infinite}
  .compass404::after{content:"";position:absolute;left:50%;top:50%;width:3px;height:30px;background:var(--accent);
    transform:translate(-50%,-50%) rotate(135deg);transform-origin:center;border-radius:2px}
  @keyframes spin{to{transform:rotate(360deg)}}
  .nf-actions{display:flex;gap:.8rem;flex-wrap:wrap;margin-top:1rem}
  @media (prefers-reduced-motion:reduce){.compass404{animation:none}}
</style>
