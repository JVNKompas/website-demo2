---
const {
  title = 'Klaar om samen aan de slag te gaan?',
  text = 'Vertel ons kort wat je wilt realiseren. Je krijgt binnen één werkdag een concreet antwoord.',
  primary = { label: 'Plan een gratis kennismaking', href: '/contact' },
  secondary = { label: 'Vraag een offerte aan', href: '/offerte' },
} = Astro.props;
---
<section class="section">
  <div class="wrap">
    <div class="cta reveal">
      <span class="cta-north" aria-hidden="true"></span>
      <div class="cta-text">
        <h2>{title}</h2>
        <p class="lead">{text}</p>
      </div>
      <div class="cta-actions">
        <a href={primary.href} class="btn btn--primary">{primary.label}</a>
        {secondary && <a href={secondary.href} class="btn btn--ghost">{secondary.label}</a>}
      </div>
    </div>
  </div>
</section>

<style>
  .cta{position:relative;overflow:hidden;display:flex;flex-wrap:wrap;gap:var(--space-4);
    align-items:center;justify-content:space-between;
    background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);
    padding:clamp(28px,5vw,56px)}
  .cta-north{position:absolute;right:-40px;top:-40px;width:200px;height:200px;border-radius:50%;
    background:radial-gradient(circle,rgba(232,93,58,.16),transparent 70%);pointer-events:none}
  .cta-text{max-width:52ch}
  .cta-text h2{font-size:var(--fs-xl)}
  .cta-text p{margin-top:.7rem}
  .cta-actions{display:flex;gap:.8rem;flex-wrap:wrap;position:relative}
  @media (max-width:640px){.cta-actions .btn{flex:1}}
</style>
