---
import { testimonials } from '../data/site.js';
const loop = [...testimonials, ...testimonials];
---
<section class="section testi-sec">
  <div class="wrap">
    <div class="testi-head reveal">
      <span class="eyebrow"><span class="idx">03</span> / Wat klanten zeggen</span>
      <h2>Ervaringen van lokale klanten</h2>
    </div>
  </div>

  <div class="marquee" aria-label="Klantenreacties">
    <div class="marquee-track">
      {loop.map((t) => (
        <figure class="testi" aria-hidden="false">
          <span class="quote-mark" aria-hidden="true">”</span>
          <blockquote>{t.quote}</blockquote>
          <figcaption class="mono">— {t.naam}, {t.rol}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .testi-head{margin-bottom:var(--space-4)}
  .testi-head h2{font-size:var(--fs-xl);margin-top:.5rem}

  .marquee{overflow:hidden;-webkit-mask-image:linear-gradient(90deg,transparent,#000 6%,#000 94%,transparent);
    mask-image:linear-gradient(90deg,transparent,#000 6%,#000 94%,transparent)}
  .marquee-track{display:flex;gap:var(--space-3);width:max-content;
    animation:marquee 70s linear infinite}
  .marquee:hover .marquee-track{animation-play-state:paused}
  @keyframes marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}

  .testi{flex:0 0 clamp(280px,32vw,400px);display:flex;flex-direction:column;gap:1rem;
    background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:var(--space-4)}
  .quote-mark{font-family:var(--font-display);font-size:3rem;line-height:.5;color:var(--copper-500);height:1.2rem}
  .testi blockquote{font-size:1.05rem;color:var(--text);line-height:1.5}
  .testi figcaption{font-size:.78rem;color:var(--text-muted);margin-top:auto}

  @media (prefers-reduced-motion:reduce){
    .marquee{overflow-x:auto}
    .marquee-track{animation:none}
  }
</style>
