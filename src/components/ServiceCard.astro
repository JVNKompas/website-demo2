---
const { d } = Astro.props;
const icons = {
  WEB: 'M3 5h18v11H3zM3 20h18M9 16v4M15 16v4',
  LOGO: 'M12 3l7 4v7l-7 4-7-4V7z M12 3v18',
  '3D': 'M12 2l8 4.5v9L12 20l-8-4.5v-9zM12 2v18M4 6.5l8 4.5 8-4.5',
  IT: 'M9 3v3M15 3v3M4 8h16v9a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2zM8 12h4M8 15h6',
};
---
<a href={`/diensten/${d.slug}`} class="card svc reveal">
  <span class="svc-icon" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" stroke-linecap="round">
      <path d={icons[d.disc]} />
    </svg>
  </span>
  <div class="svc-badges">
    <span class="badge">{d.disc}</span>
    {d.beschikbaarVanaf && <span class="badge svc-soon">Vanaf {d.beschikbaarVanaf}</span>}
  </div>
  <h3 class="svc-title">{d.titel}</h3>
  <p class="muted svc-text">{d.kaartTekst}</p>
  <div class="svc-foot">
    <span class="link-arrow svc-more">Meer info <span class="a">→</span></span>
  </div>
</a>

<style>
  .svc{display:flex;flex-direction:column;gap:.7rem;height:100%}
  .svc-icon{width:44px;height:44px;color:var(--accent);margin-bottom:.4rem}
  .svc-icon svg{width:100%;height:100%}
  .svc-badges{display:flex;gap:.4rem;flex-wrap:wrap;align-items:center}
  .svc-soon{color:var(--warning);border-color:color-mix(in srgb,var(--warning) 45%,transparent)}
  .svc-title{font-size:var(--fs-md)}
  .svc-text{flex:1}
  .svc-foot{margin-top:.6rem;padding-top:.9rem;border-top:1px solid var(--border)}
  .svc-more{white-space:nowrap}
</style>
