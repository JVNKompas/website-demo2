---
const { items, title = 'Veelgestelde vragen' } = Astro.props;
---
<section class="section" id="faq">
  <div class="wrap faq-wrap">
    <div class="faq-head">
      <span class="eyebrow"><span class="idx">FAQ</span> / Antwoorden</span>
      <h2>{title}</h2>
    </div>
    <div class="faq-list">
      {items.map((it) => (
        <details class="faq-item reveal">
          <summary>
            <span>{it.q}</span>
            <span class="faq-chevron" aria-hidden="true">+</span>
          </summary>
          <div class="faq-answer"><p>{it.a}</p></div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-wrap{display:grid;grid-template-columns:.8fr 1.6fr;gap:var(--space-5);align-items:start}
  .faq-head h2{font-size:var(--fs-xl);margin-top:.6rem}
  .faq-item{border-bottom:1px solid var(--border)}
  .faq-item summary{list-style:none;cursor:pointer;display:flex;justify-content:space-between;
    gap:1rem;align-items:center;padding:1.1rem 0;font-family:var(--font-display);font-weight:600;font-size:1.1rem}
  .faq-item summary::-webkit-details-marker{display:none}
  .faq-chevron{color:var(--accent);font-size:1.4rem;transition:transform var(--dur-base) var(--ease-standard);flex:none}
  .faq-item[open] .faq-chevron{transform:rotate(45deg)}
  .faq-answer{padding-bottom:1.2rem;color:var(--slate-300);max-width:62ch}
  @media (max-width:820px){.faq-wrap{grid-template-columns:1fr}}
</style>
