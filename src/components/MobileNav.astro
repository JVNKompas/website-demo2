---
/*
  MobileNav — één herbruikbare, fullscreen mobiele navigatie.
  Wordt op body-niveau gerenderd (zie Header.astro), buiten elke sticky/
  backdrop-filter-context, zodat de overlay nooit "gevangen" raakt in een
  stacking context of containing block van de header.
  Aangestuurd door de burger-knop (#burger) in Header.astro.
*/
import { nav, diensten, site } from '../data/site.js';
---
<div
  class="mnav"
  id="mobileNav"
  role="dialog"
  aria-modal="true"
  aria-label="Mobiele navigatie"
  aria-hidden="true"
  hidden
>
  <div class="mnav__top">
    <a href="/" class="mnav__brand" aria-label={`${site.naam} — home`}>
      <span class="mnav__mark" aria-hidden="true"></span>
      <span>JVN <span class="mnav__accent">Kompas</span></span>
    </a>
    <button class="mnav__close" id="mnavClose" type="button" aria-label="Menu sluiten">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <path d="M6 6l12 12M18 6L6 18" />
      </svg>
    </button>
  </div>

  <nav class="mnav__nav" aria-label="Hoofdnavigatie">
    <a href="/diensten" class="mnav__link"><span class="mnav__idx" aria-hidden="true">01</span>Diensten</a>
    <div class="mnav__subs">
      {diensten.map((d) => (
        <a href={`/diensten/${d.slug}`} class="mnav__sub">
          <span class="mono mnav__disc" aria-hidden="true">{d.disc}</span>{d.titel}
        </a>
      ))}
    </div>
    {nav.filter((n) => n.href !== '/diensten').map((n, i) => (
      <a href={n.href} class="mnav__link">
        <span class="mnav__idx" aria-hidden="true">{String(i + 2).padStart(2, '0')}</span>{n.label}
      </a>
    ))}
  </nav>

  <div class="mnav__bottom">
    <a href="/contact" class="btn btn--primary mnav__cta">Contact opnemen</a>
    <div class="mnav__meta">
      <a href={`mailto:${site.email}`} class="mnav__metalink">{site.email}</a>
      <a href={`tel:${site.telefoonHref}`} class="mnav__metalink">{site.telefoon}</a>
    </div>
  </div>
</div>

<style>
  .mnav{
    position:fixed;
    inset:0;
    width:100vw;
    height:100vh;          /* fallback */
    height:100dvh;
    z-index:9999;
    background:var(--onyx-950);   /* volledig ondoorzichtig, donker thema */
    display:flex;
    flex-direction:column;
    gap:var(--space-4);
    padding:
      calc(env(safe-area-inset-top,0px) + 18px)
      var(--gutter)
      calc(env(safe-area-inset-bottom,0px) + 24px);
    overflow-y:auto;
    overscroll-behavior:contain;
    -webkit-overflow-scrolling:touch;
    opacity:0;
    transform:translateY(-8px);
    visibility:hidden;
    pointer-events:none;
    transition:
      opacity 250ms ease-out,
      transform 250ms ease-out,
      visibility 250ms ease-out;
  }
  .mnav.open{
    opacity:1;
    transform:translateY(0);
    visibility:visible;
    pointer-events:auto;
  }

  /* ----- Top: logo + sluitknop ----- */
  .mnav__top{
    display:flex;align-items:center;justify-content:space-between;
    flex-shrink:0;
  }
  .mnav__brand{
    display:inline-flex;align-items:center;gap:.6rem;
    font-family:var(--font-display);font-weight:700;font-size:1.15rem;color:var(--text);
  }
  .mnav__mark{
    width:16px;height:16px;transform:rotate(45deg);
    background:conic-gradient(from 45deg,var(--copper-500),var(--copper-700),var(--copper-500));
    box-shadow:0 0 12px rgba(232,93,58,.5);
  }
  .mnav__accent{color:var(--accent)}
  .mnav__close{
    display:grid;place-items:center;
    width:44px;height:44px;margin-right:-8px;
    background:transparent;border:1px solid var(--border);border-radius:var(--radius-md);
    color:var(--text);cursor:pointer;
    transition:border-color var(--dur-base) var(--ease-standard),color var(--dur-base) var(--ease-standard);
  }
  .mnav__close:hover{border-color:var(--accent);color:var(--accent-hover)}
  .mnav__close svg{width:22px;height:22px}

  /* ----- Midden: navigatielinks ----- */
  .mnav__nav{
    display:flex;flex-direction:column;
    justify-content:center;
    flex:1 1 auto;
    min-height:0;
    gap:.1rem;
  }
  .mnav__link{
    display:flex;align-items:baseline;gap:.9rem;
    font-family:var(--font-display);font-weight:600;font-size:clamp(1.9rem,9vw,2.6rem);
    line-height:1.15;color:var(--text);padding:.35rem 0;
    transition:color var(--dur-base) var(--ease-standard);
  }
  .mnav__link:hover{color:var(--accent)}
  .mnav__idx{
    font-family:var(--font-mono);font-size:.8rem;font-weight:500;
    color:var(--accent);transform:translateY(-.6em);
  }
  .mnav__subs{
    display:flex;flex-direction:column;
    margin:.4rem 0 .8rem 1.9rem;
    padding-left:1rem;border-left:1px solid var(--border);
  }
  .mnav__sub{
    display:flex;align-items:center;gap:.7rem;
    color:var(--text-muted);padding:.5rem 0;font-size:1rem;
    transition:color var(--dur-base) var(--ease-standard);
  }
  .mnav__sub:hover{color:var(--text)}
  .mnav__disc{color:var(--accent);font-size:.72rem;min-width:2.6em}

  /* ----- Onder: CTA + contact ----- */
  .mnav__bottom{
    display:flex;flex-direction:column;gap:1rem;
    flex-shrink:0;
  }
  .mnav__cta{width:100%}
  .mnav__meta{
    display:flex;flex-wrap:wrap;gap:.4rem 1.4rem;
    font-family:var(--font-mono);font-size:var(--fs-sm);
  }
  .mnav__metalink{color:var(--text-muted);transition:color var(--dur-base) var(--ease-standard)}
  .mnav__metalink:hover{color:var(--accent)}

  /* Nooit tonen op desktop — daar geldt de horizontale nav. */
  @media (min-width:901px){
    .mnav{display:none}
  }

  /* Respecteer reduced-motion (global.css nult transitions al, dit is extra zekerheid). */
  @media (prefers-reduced-motion:reduce){
    .mnav{transition:opacity 1ms linear,visibility 1ms linear;transform:none}
    .mnav.open{transform:none}
  }
</style>

<script>
  const menu = document.getElementById('mobileNav');
  const burger = document.getElementById('burger');
  const closeBtn = document.getElementById('mnavClose');

  if (menu && burger) {
    // Elementen die op de achtergrond onbereikbaar moeten worden voor toetsenbord + AT.
    const backgrounds = ['main', 'siteFooter', 'toTop']
      .map((id) => document.getElementById(id))
      .filter(Boolean);

    const focusableSelector =
      'a[href], button:not([disabled]), input, textarea, select, [tabindex]:not([tabindex="-1"])';
    let lastFocused = null;

    const setBackgroundInert = (on) => {
      backgrounds.forEach((el) => {
        if (on) el.setAttribute('inert', '');
        else el.removeAttribute('inert');
      });
    };

    const open = () => {
      lastFocused = document.activeElement;
      menu.hidden = false;
      // Forceer reflow zodat de transitie speelt na hidden→zichtbaar.
      void menu.offsetWidth;
      menu.classList.add('open');
      menu.setAttribute('aria-hidden', 'false');
      burger.setAttribute('aria-expanded', 'true');
      burger.setAttribute('aria-label', 'Menu sluiten');
      document.body.classList.add('menu-open');
      setBackgroundInert(true);
      (closeBtn || menu.querySelector(focusableSelector))?.focus();
      document.addEventListener('keydown', onKeydown);
    };

    const close = () => {
      menu.classList.remove('open');
      menu.setAttribute('aria-hidden', 'true');
      burger.setAttribute('aria-expanded', 'false');
      burger.setAttribute('aria-label', 'Menu openen');
      document.body.classList.remove('menu-open');
      setBackgroundInert(false);
      document.removeEventListener('keydown', onKeydown);
      const done = () => {
        // Niet verbergen als de gebruiker intussen opnieuw geopend heeft.
        if (!menu.classList.contains('open')) menu.hidden = true;
        menu.removeEventListener('transitionend', done);
      };
      // Verberg pas na de fade-out; val terug op timeout als er geen transition speelt.
      menu.addEventListener('transitionend', done);
      window.setTimeout(done, 320);
      if (lastFocused instanceof HTMLElement) lastFocused.focus();
    };

    const onKeydown = (e) => {
      if (e.key === 'Escape') {
        e.preventDefault();
        close();
        return;
      }
      if (e.key !== 'Tab') return;
      // Focus-trap: houd Tab binnen de overlay.
      const items = [...menu.querySelectorAll(focusableSelector)].filter(
        (el) => el.offsetParent !== null || el === document.activeElement
      );
      if (!items.length) return;
      const first = items[0];
      const last = items[items.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    };

    const isOpen = () => menu.classList.contains('open');

    burger.addEventListener('click', () => (isOpen() ? close() : open()));
    closeBtn?.addEventListener('click', close);
    // Sluit bij navigeren naar een link.
    menu.addEventListener('click', (e) => {
      if (e.target.closest('a')) close();
    });

    // Sluit automatisch wanneer we naar desktop-breedte gaan.
    const mq = window.matchMedia('(min-width:901px)');
    mq.addEventListener('change', (e) => {
      if (e.matches && isOpen()) close();
    });
  }
</script>
