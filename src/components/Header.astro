---
import { nav, diensten, site } from '../data/site.js';
const path = Astro.url.pathname;
const isActive = (href) => href === '/' ? path === '/' : path.startsWith(href);
---
<header class="site-header" id="siteHeader">
  <div class="wrap header-inner">
    <a href="/" class="brand" aria-label={`${site.naam} — home`}>
      <span class="brand-mark" aria-hidden="true"></span>
      <span class="brand-name">JVN <span class="brand-accent">Kompas</span></span>
    </a>

    <nav class="nav-desktop" aria-label="Hoofdnavigatie">
      <div class="nav-item has-sub">
        <a href="/diensten" class:list={["nav-link", { active: isActive('/diensten') }]} aria-haspopup="true">Diensten</a>
        <div class="submenu" role="menu">
          {diensten.map((d) => (
            <a role="menuitem" href={`/diensten/${d.slug}`} class="submenu-link">
              <span class="mono submenu-disc">{d.disc}</span>{d.titel}
            </a>
          ))}
        </div>
      </div>
      {nav.filter(n => n.href !== '/diensten').map((n) => (
        <a href={n.href} class:list={["nav-link", { active: isActive(n.href) }]}>{n.label}</a>
      ))}
      <a href="/contact" class="btn btn--primary nav-cta">Contact</a>
    </nav>

    <button class="burger" id="burger" aria-label="Menu openen" aria-expanded="false" aria-controls="drawer">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="drawer" id="drawer" hidden>
    <nav class="drawer-nav" aria-label="Mobiele navigatie">
      <a href="/diensten" class="drawer-link">Diensten</a>
      {diensten.map((d) => (
        <a href={`/diensten/${d.slug}`} class="drawer-sub"><span class="mono">{d.disc}</span> {d.titel}</a>
      ))}
      {nav.filter(n => n.href !== '/diensten').map((n) => (
        <a href={n.href} class="drawer-link">{n.label}</a>
      ))}
      <a href="/contact" class="btn btn--primary drawer-cta">Contact</a>
    </nav>
  </div>
</header>

<style>
  .site-header{position:sticky;top:0;z-index:100;
    background:transparent;border-bottom:1px solid transparent;
    transition:background var(--dur-base) var(--ease-standard),border-color var(--dur-base) var(--ease-standard),backdrop-filter var(--dur-base) var(--ease-standard)}
  .site-header.scrolled{background:rgba(26,26,26,.92);border-bottom-color:var(--border);backdrop-filter:blur(8px)}
  .header-inner{display:flex;align-items:center;justify-content:space-between;height:72px}
  .brand{display:inline-flex;align-items:center;gap:.6rem;font-family:var(--font-display);font-weight:700;font-size:1.15rem}
  .brand-mark{width:16px;height:16px;transform:rotate(45deg);
    background:conic-gradient(from 45deg,var(--copper-500),var(--copper-700),var(--copper-500));
    box-shadow:0 0 12px rgba(232,93,58,.5)}
  .brand-accent{color:var(--accent)}
  .nav-desktop{display:flex;align-items:center;gap:1.6rem}
  .nav-link{font-size:.95rem;color:var(--text-muted);transition:color var(--dur-base) var(--ease-standard)}
  .nav-link:hover,.nav-link.active{color:var(--text)}
  .nav-link.active{position:relative}
  .nav-item{position:relative}
  .has-sub .submenu{position:absolute;top:calc(100% + 14px);left:-16px;min-width:260px;
    background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);
    padding:.5rem;box-shadow:var(--elev-2);opacity:0;visibility:hidden;transform:translateY(6px);
    transition:opacity var(--dur-fast) var(--ease-standard),transform var(--dur-fast) var(--ease-standard),visibility var(--dur-fast)}
  .has-sub:hover .submenu,.has-sub:focus-within .submenu{opacity:1;visibility:visible;transform:none}
  .submenu-link{display:flex;align-items:center;gap:.7rem;padding:.6rem .7rem;border-radius:var(--radius-md);color:var(--text)}
  .submenu-link:hover{background:var(--onyx-800)}
  .submenu-disc{color:var(--accent);font-size:.7rem;min-width:2.5em}
  .nav-cta{min-height:40px;padding:0 1.1rem}
  .burger{display:none;flex-direction:column;gap:5px;background:none;border:0;cursor:pointer;padding:10px}
  .burger span{width:24px;height:2px;background:var(--text);transition:transform var(--dur-base) var(--ease-standard),opacity var(--dur-base)}
  .burger[aria-expanded="true"] span:nth-child(1){transform:translateY(7px) rotate(45deg)}
  .burger[aria-expanded="true"] span:nth-child(2){opacity:0}
  .burger[aria-expanded="true"] span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}
  .drawer{position:fixed;inset:72px 0 0 0;background:var(--bg);z-index:99;padding:var(--gutter);
    animation:drawerIn var(--dur-entrance) var(--ease-decel)}
  @keyframes drawerIn{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:none}}
  .drawer-nav{display:flex;flex-direction:column;gap:.2rem}
  .drawer-link{font-family:var(--font-display);font-size:1.6rem;font-weight:600;padding:.6rem 0;border-bottom:1px solid var(--border)}
  .drawer-sub{color:var(--text-muted);padding:.5rem 0 .5rem 1rem;display:flex;gap:.7rem}
  .drawer-sub .mono{color:var(--accent);font-size:.75rem}
  .drawer-cta{margin-top:1.5rem;width:100%}
  @media (max-width:900px){
    .nav-desktop{display:none}
    .burger{display:flex}
  }
</style>

<script>
  const header = document.getElementById('siteHeader');
  const onScroll = () => header?.classList.toggle('scrolled', window.scrollY > 12);
  onScroll(); window.addEventListener('scroll', onScroll, { passive: true });

  const burger = document.getElementById('burger');
  const drawer = document.getElementById('drawer');
  const toggle = (open) => {
    burger.setAttribute('aria-expanded', String(open));
    burger.setAttribute('aria-label', open ? 'Menu sluiten' : 'Menu openen');
    drawer.hidden = !open;
    document.body.style.overflow = open ? 'hidden' : '';
  };
  burger?.addEventListener('click', () => toggle(drawer.hidden));
  drawer?.addEventListener('click', (e) => { if (e.target.tagName === 'A') toggle(false); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !drawer.hidden) toggle(false); });
</script>
