---
import { site, diensten } from '../data/site.js';
const jaar = new Date().getFullYear();
---
<footer class="site-footer" id="siteFooter">
  <div class="wrap">
    <div class="foot-top">
      <div class="foot-brand">
        <a href="/" class="brand"><span class="brand-mark" aria-hidden="true"></span>
          <span class="brand-name">JVN <span class="brand-accent">Kompas</span></span></a>
        <p class="muted foot-tag">{site.slogan}</p>
      </div>

      <nav class="foot-cols" aria-label="Footernavigatie">
        <div class="foot-col">
          <h4>Diensten</h4>
          {diensten.map((d) => <a href={`/diensten/${d.slug}`}>{d.titel}</a>)}
          <a href="/offerte">Offerte aanvragen</a>
        </div>
        <div class="foot-col">
          <h4>Links</h4>
          <a href="/over">Over</a>
          <a href="/werk">Werk</a>
          <a href="/contact">Contact</a>
        </div>
        <div class="foot-col">
          <h4>Contact</h4>
          <a href={`mailto:${site.email}`}>{site.email}</a>
          <a href={`tel:${site.telefoonHref}`}>{site.telefoon}</a>
          <span class="muted mono">BTW {site.btw}</span>
        </div>
      </nav>
    </div>

    <div class="foot-bottom">
      <span class="muted">© {jaar} JVN Kompas</span>
      <nav class="legal-links" aria-label="Juridisch">
        <a href="/privacybeleid">Privacybeleid</a>
        <a href="/voorwaarden">Algemene voorwaarden</a>
        <a href="/cookiebeleid">Cookiebeleid</a>
      </nav>
    </div>
  </div>
</footer>

<style>
  .site-footer{border-top:1px solid var(--border);background:var(--onyx-900);padding-block:var(--space-6) var(--space-4);margin-top:var(--space-7)}
  .brand{display:inline-flex;align-items:center;gap:.6rem;font-family:var(--font-display);font-weight:700;font-size:1.15rem}
  .brand-mark{width:16px;height:16px;transform:rotate(45deg);background:conic-gradient(from 45deg,var(--copper-500),var(--copper-700),var(--copper-500))}
  .brand-accent{color:var(--accent)}
  .foot-tag{margin-top:.8rem;max-width:34ch;font-family:var(--font-display);font-size:1.05rem;color:var(--slate-300)}
  .foot-top{display:grid;grid-template-columns:1.3fr 2fr;gap:var(--space-5)}
  .foot-cols{display:grid;grid-template-columns:repeat(3,1fr);gap:var(--space-3)}
  .foot-col{display:flex;flex-direction:column;gap:.55rem}
  .foot-col h4{font-family:var(--font-mono);font-size:.75rem;letter-spacing:.12em;text-transform:uppercase;color:var(--text-muted);margin-bottom:.4rem;font-weight:500}
  .foot-col a{color:var(--slate-300);font-size:.92rem}
  .foot-col a:hover{color:var(--accent)}
  .foot-bottom{display:flex;justify-content:space-between;align-items:center;gap:1rem;flex-wrap:wrap;
    margin-top:var(--space-5);padding-top:var(--space-3);border-top:1px solid var(--border);font-size:.85rem}
  .legal-links{display:flex;gap:1.2rem;flex-wrap:wrap}
  .legal-links a{color:var(--text-muted)}
  .legal-links a:hover{color:var(--accent)}
  @media (max-width:820px){
    .foot-top{grid-template-columns:1fr}
    .foot-cols{grid-template-columns:repeat(2,1fr)}
  }
  @media (max-width:480px){
    .foot-bottom{flex-direction:column;gap:.8rem;align-items:flex-start}
    .foot-cols{grid-template-columns:1fr}
  }
</style>
