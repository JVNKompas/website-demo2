---
const { c } = Astro.props;
---
<a href={`/werk/${c.slug}`} class="work reveal" data-disc={c.disc}>
  <div class="work-thumb" style={`--c:${c.kleur}`}>
    <span class="badge work-badge">{c.disc}</span>
    <span class="work-north" aria-hidden="true"></span>
  </div>
  <div class="work-body">
    <h3 class="work-title">{c.titel}</h3>
    <p class="mono work-meta">{c.klant} · {c.jaar}</p>
  </div>
</a>

<style>
  .work{display:block}
  .work-thumb{position:relative;aspect-ratio:16/10;border-radius:var(--radius-lg);overflow:hidden;
    background:linear-gradient(145deg,var(--c),var(--onyx-900));border:1px solid var(--border);
    transition:border-color var(--dur-base) var(--ease-standard),transform var(--dur-base) var(--ease-standard)}
  .work-thumb::after{content:"";position:absolute;inset:0;
    background:radial-gradient(circle at 70% 30%,rgba(232,93,58,.18),transparent 55%)}
  .work:hover .work-thumb{transform:translateY(-4px);border-color:var(--copper-600)}
  .work-badge{position:absolute;top:12px;left:12px;z-index:2}
  .work-north{position:absolute;right:16px;bottom:16px;width:14px;height:14px;transform:rotate(45deg) scale(.6);
    background:var(--accent);opacity:0;transition:opacity var(--dur-base) var(--ease-standard),transform var(--dur-base) var(--ease-standard);z-index:2}
  .work:hover .work-north{opacity:1;transform:rotate(45deg) scale(1)}
  .work-body{padding:.9rem .2rem}
  .work-title{font-size:1.15rem;transition:color var(--dur-base) var(--ease-standard)}
  .work:hover .work-title{color:var(--accent)}
  .work-meta{font-size:.78rem;color:var(--text-muted);margin-top:.35rem}
</style>
